# ════════════════════════════════════════════
#   Imobiliária IA Platform - Configuração
# ════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores

# ── Anthropic (Claude) ──────────────────────
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# ── WhatsApp (Evolution API) ────────────────
# Instale: https://doc.evolution-api.com
# Alternativa: Z-API (https://z-api.io)
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_API_TOKEN=seu_token_aqui
WHATSAPP_INSTANCE=minha_instancia

# ── Twilio (Ligações automatizadas) ─────────
# Cadastre em: https://twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=seu_auth_token_twilio
TWILIO_PHONE_NUMBER=+5511999999999

# ── Configurações gerais ────────────────────
DATABASE_URL=sqlite:///./imobiliaria.db
SCRAPING_DELAY=2.0
